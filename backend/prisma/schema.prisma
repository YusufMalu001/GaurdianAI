
generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String             @id @default(uuid())
  name            String
  email           String             @unique
  phone           String?
  passwordHash    String             @map("password_hash")
  avatarUrl       String?            @map("avatar_url")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")
  trustedContacts TrustedContact[]
  incidents       Incident[]
  sosEvents       SOSEvent[]
  trips           Trip[]

  @@map("users")
}

model TrustedContact {
  id                 String              @id @default(uuid())
  userId             String              @map("user_id")
  contactName        String              @map("contact_name")
  phoneNumber        String              @map("phone_number")
  email              String?
  relationship       String?
  isPriority         Boolean             @default(false) @map("is_priority")
  guardianUserId     String?             @map("guardian_user_id")
  createdAt          DateTime            @default(now()) @map("created_at")
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  alertNotifications EmergencyNotification[]

  @@map("trusted_contacts")
}

model Incident {
  id          String    @id @default(uuid())
  userId      String?   @map("user_id")
  lat         Float
  lng         Float
  type        String
  description String?
  riskLevel   String    @default("MEDIUM") @map("risk_level")
  reportedAt  DateTime  @default(now()) @map("reported_at")
  verified    Boolean   @default(false)
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([lat, lng], map: "idx_incidents_location")
  @@map("incidents")
}

model SOSEvent {
  id                     String                  @id @default(uuid())
  userId                 String                  @map("user_id")
  lat                    Float
  lng                    Float
  status                 String                  @default("ACTIVE")
  batteryLevel           Int?                    @map("battery_level")
  triggeredAt            DateTime                @default(now()) @map("triggered_at")
  resolvedAt             DateTime?               @map("resolved_at")
  user                   User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  emergencyNotifications EmergencyNotification[]
  liveTrackingSessions   LiveTrackingSession[]

  @@index([userId], map: "idx_sos_events_user")
  @@map("sos_events")
}

model LiveTrackingSession {
  id        String    @id @default(uuid())
  sosEventId String   @map("sos_event_id")
  status    String    @default("ACTIVE") // ACTIVE, ENDED
  startedAt DateTime  @default(now()) @map("started_at")
  endedAt   DateTime? @map("ended_at")
  sosEvent  SOSEvent  @relation(fields: [sosEventId], references: [id], onDelete: Cascade)

  @@index([sosEventId], map: "idx_tracking_session_sos_event")
  @@map("live_tracking_sessions")
}

model EmergencyNotification {
  id         String          @id @default(uuid())
  sosEventId String          @map("sos_event_id")
  contactId  String?         @map("contact_id")
  sentAt     DateTime        @default(now()) @map("sent_at")
  delivered  Boolean         @default(false)
  type       String          @default("PUSH") // PUSH, SMS, EMAIL
  sosEvent   SOSEvent        @relation(fields: [sosEventId], references: [id], onDelete: Cascade)
  contact    TrustedContact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@map("emergency_notifications")
}

model EmergencyLog {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  event     String
  details   Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("emergency_logs")
}

model Trip {
  id              String    @id @default(uuid())
  userId          String    @map("user_id")
  originLat       Float?    @map("origin_lat")
  originLng       Float?    @map("origin_lng")
  destLat         Float?    @map("dest_lat")
  destLng         Float?    @map("dest_lng")
  safetyScore     Int?      @map("safety_score")
  distanceKm      Decimal?  @map("distance_km") @db.Decimal(8, 2)
  durationMinutes Int?      @map("duration_minutes")
  startedAt       DateTime  @default(now()) @map("started_at")
  endedAt         DateTime? @map("ended_at")
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_trips_user")
  @@map("trips")
}